{
  "name": "@hermes/desktop-adapter",
  "version": "0.0.1",
  "private": true,
  "description": "OS-agnostic DesktopAdapter interface. Implementations live in OS-specific packages (mac/windows).",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./macos": "./src/macos.ts",
    "./sidecar-client": "./src/sidecar-client.ts",
    "./desktop-provider": "./src/desktop-provider.ts",
    "./handlers": "./src/handlers.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hermes/engine": "workspace:*",
    "@hermes/ir": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
