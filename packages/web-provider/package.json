{
  "name": "@hermes/web-provider",
  "version": "0.0.1",
  "private": true,
  "description": "Playwright-backed Web Provider: launches a per-flow Chromium profile and executes web Steps.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./handlers": "./src/handlers.ts",
    "./provider": "./src/web-provider.ts",
    "./selector": "./src/selector.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hermes/engine": "workspace:*",
    "@hermes/ir": "workspace:*",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
