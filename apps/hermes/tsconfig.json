{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@main/*": ["src/main/*"],
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    },
    "types": ["node", "electron-vite/node"],
    "noEmit": true
  },
  "include": ["src/**/*", "electron.vite.config.ts", "electron-builder.yml"]
}
