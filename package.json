{
  "name": "hermes",
  "version": "0.0.1",
  "private": true,
  "description": "3-in-1 RPA app: deterministic recorder/editor/runtime, with optional AI assertion and generation layers.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm -F @hermes/app dev",
    "build:mac": "pnpm -F @hermes/app build:mac",
    "lint": "pnpm -r --parallel run lint",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r --parallel run test",
    "test:run": "pnpm -r --parallel run test:run",
    "clean": "pnpm -r --parallel run clean",
    "format": "prettier --write .",
    "sidecar:mac:build": "swift build --package-path sidecars/macos-native -c release"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
